{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["../server/src/*"]
    }
  },
  "include": [
    "../server/src/**/*.ts",
    "./**/*.ts"
  ],
  "exclude": [
    "../node_modules",
    "../dist"
  ]
}
