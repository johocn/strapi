{
  "extends": "@strapi/typescript-utils/tsconfigs/server",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./server/src/*"]
    }
  },
  "include": [
    "server/src/**/*.ts",
    "admin/src/**/*.ts",
    "admin/src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}