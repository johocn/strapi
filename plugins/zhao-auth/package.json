{
  "name": "zhao-auth",
  "version": "1.0.0",
  "description": "统一认证策略中间件插件 - JWT 验证、角色授权、渠道权限",
  "private": true,
  "keywords": [],
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test:ts:back": "tsc -p server/tsconfig.json",
    "test": "jest --config tests/jest.config.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@strapi/sdk-plugin": "^6.1.0",
    "@strapi/strapi": "^5.45.0",
    "@strapi/typescript-utils": "^5.45.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^25.9.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@strapi/strapi": "^5.45.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "strapi": {
    "kind": "plugin",
    "name": "zhao-auth",
    "displayName": "Zhao Auth",
    "description": "统一认证策略中间件插件 - JWT 验证、角色授权、渠道权限"
  },
  "license": "MIT"
}
