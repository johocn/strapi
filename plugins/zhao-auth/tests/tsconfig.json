{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "types": ["jest", "node", "@testing-library/jest-dom"]
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "../server/src/**/*.ts",
    "../admin/src/**/*.ts",
    "../admin/src/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist"]
}
