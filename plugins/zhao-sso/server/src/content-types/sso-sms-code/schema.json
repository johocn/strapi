{
  "kind": "collectionType",
  "collectionName": "sso_sms_codes",
  "info": {
    "singularName": "sso-sms-code",
    "pluralName": "sso-sms-codes",
    "displayName": "SSO SMS Code"
  },
  "options": { "draftAndPublish": false },
  "attributes": {
    "mobile": { "type": "string", "required": true },
