{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./server/src",
    "baseUrl": ".",
    "paths": {
      "@strapi/strapi": ["../../node_modules/@strapi/strapi"],
      "@strapi/utils": ["../../node_modules/@strapi/utils"]
    },
    "types": ["node"]
  },
  "include": ["server/src/**/*"],
  "exclude": ["node_modules", "dist"]
}