{
  "kind": "collectionType",
  "collectionName": "zhao_studio_sync_events",
  "info": {
    "singularName": "sync-event",
    "pluralName": "sync-events",
    "displayName": "同步事件"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": { "visible": true },
    "content-type-builder": { "visible": false }
  },
  "attributes": {
    "site": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::zhao-common.site-config",
      "required": true,
      "inversedBy": "studio_sync_events"
    },
    "sourceType": {
      "type": "enumeration",
      "enum": ["website"],
      "required": true
    },
    "sourceContentType": {
      "type": "string",
      "required": true
    },
    "sourceDocumentId": {
      "type": "string"
    },
    "sourceUrl": {
      "type": "string"
    },
    "sourceTitle": {
      "type": "string"
    },
    "targetDraftId": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::zhao-studio.article-draft",
      "inversedBy": "syncEvents"
    },
    "eventStatus": {
      "type": "enumeration",
      "enum": ["pending", "resolved", "ignored"],
      "default": "pending"
    },
    "eventPayload": {
      "type": "json"
    },
    "resolvedAt": {
      "type": "datetime"
    },
    "resolvedBy": {
      "type": "string"
    }
  }
}