{
  "extends": "@strapi/typescript-utils/tsconfigs/server",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./server/src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./server/src/*"]
    },
    "noEmit": false,
    "noEmitOnError": false,
    "skipLibCheck": true
  },
  "include": [
    "server/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "admin"
  ]
}
