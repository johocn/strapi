{
  "extends": "@strapi/typescript-utils/tsconfigs/default",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["server/src/**/*.ts", "admin/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
