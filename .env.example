# Redis (zhao-channel 插件使用 Bull 队列)
# 代码使用 REDIS_URL 连接 Redis，格式：redis://[:密码@]主机:端口
# 无密码：redis://localhost:6379
# 有密码：redis://:你的密码@localhost:6379
# 密码含特殊字符（@ : / # 等）必须 URL 编码：
#   @ → %40   : → %3A   / → %2F   # → %23
#   例：密码 "joho@963963" → redis://:joho%40963963@localhost:6379
REDIS_URL=redis://localhost:6379

# 兼容字段（部分脚本可能使用，建议同时设置）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Aliyun OSS (zhao-oss) - 可选，不配置则使用本地存储
ALIYUN_OSS_REGION=
ALIYUN_OSS_ACCESS_KEY=
ALIYUN_OSS_ACCESS_SECRET=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_CNAME=