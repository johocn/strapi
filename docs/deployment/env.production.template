# ============================================
# Strapi 生产环境变量模板
# 使用方式：复制为 .env 并填写实际值
# ============================================

# Server
HOST=127.0.0.1
PORT=1337

# Database (PostgreSQL)
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=替换为强密码
DATABASE_SSL=false
DATABASE_SCHEMA=public

# Redis (zhao-channel 用)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=如有密码则填写

# Strapi Secrets（使用 openssl rand -base64 32 生成）
APP_KEYS=替换为生成的key1,替换为生成的key2
API_TOKEN_SALT=替换为生成的salt
ADMIN_JWT_SECRET=替换为生成的secret
TRANSFER_TOKEN_SALT=替换为生成的salt
JWT_SECRET=替换为生成的secret

# SMS Provider (zhao-sso 用)
# 可选值: mock, aliyun, tencent
SMS_PROVIDER=mock
# 阿里云短信（SMS_PROVIDER=aliyun 时填写）
SMS_ALIYUN_ACCESS_KEY_ID=
SMS_ALIYUN_ACCESS_KEY_SECRET=
SMS_ALIYUN_SIGN_NAME=
SMS_ALIYUN_TEMPLATE_CODE=
# 腾讯云短信（SMS_PROVIDER=tencent 时填写）
SMS_TENCENT_SECRET_ID=
SMS_TENCENT_SECRET_KEY=
SMS_TENCENT_SDK_APP_ID=
SMS_TENCENT_SIGN_NAME=
SMS_TENCENT_TEMPLATE_ID=

# 阿里云 OSS（可选，未配置则使用本地文件存储）
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_REGION=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_CUSTOM_DOMAIN=

# SSO OAuth 回调地址（生产域名）
SSO_REDIRECT_BASE_URL=https://h.joho.cn
